# Google OAuth credentials for YouTube read-only access.
# Get these from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs.
# Enable the YouTube Data API v3 and YouTube Analytics API on the same project.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# NextAuth config. NEXTAUTH_URL must match the deployed origin.
# Generate a strong NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# SMTP config for sending application emails via nodemailer.
# Works with any SMTP provider (Gmail, SendGrid, Resend, Postmark, etc.).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password

# Supabase — get these from your project dashboard at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Clerk — get these from dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Upstash Redis for rate limiting. Create a free database at console.upstash.com.
# Copy the REST URL and REST token from the database's "REST API" section.
# If these are unset, rate limiting is a no-op (safe to deploy without them, but add them before launch).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token
